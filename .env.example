# FK-AOS (Franchise Kart Autonomous Operating System) — Environment Variables
# Copy to .env.local for local development
# Copy to .env.production for production (Vercel Dashboard → Environment Variables)

# ============================================================
# REQUIRED — Frontend (bundled at build time via VITE_ prefix)
# ============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# REQUIRED — Supabase Edge Functions (set via Supabase Dashboard → Edge Functions → Secrets)
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# REQUIRED — AI Engine (Anthropic Claude + OpenAI)
# ============================================================
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ============================================================
# REQUIRED — Payments (Razorpay)
# ============================================================
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ============================================================
# REQUIRED — WhatsApp Business (Meta Cloud API)
# ⚠️ BLOCKER: Requires Meta Business verification + WhatsApp Business API approval
# Founder action: Meta Business Suite → WhatsApp Manager → API Setup
# Without these, whatsapp-send and whatsapp-template-manager will throw clear errors
# ============================================================
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token
META_WEBHOOK_VERIFY_TOKEN=your-meta-verify-token

# ============================================================
# REQUIRED — LinkedIn Integration
# ============================================================
LINKEDIN_WEBHOOK_VERIFY_TOKEN=your-linkedin-verify-token
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token

# ============================================================
# REQUIRED — Google Calendar OAuth
# ⚠️ BLOCKER: Requires Google Cloud Console OAuth consent screen + credential setup
# Founder action: Google Cloud Console → APIs & Services → OAuth 2.0 → Calendar API
# Without these, calendar-sync will throw clear errors
# ============================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key
GOOGLE_CALENDAR_ID=your-calendar-id@example.com

# ============================================================
# REQUIRED — CRM Webhook Authentication
# ============================================================
CRM_WEBHOOK_SECRET=your-crm-webhook-secret

# ============================================================
# OPTIONAL — Observability
# ============================================================
# Sentry Backend (set in Supabase Edge Function secrets)
SENTRY_DSN=your-sentry-dsn

# Sentry Frontend (bundled at build time via VITE_ prefix)
VITE_SENTRY_DSN=your-sentry-frontend-dsn

# ============================================================
# OPTIONAL — PostHog Analytics
# ============================================================
VITE_POSTHOG_KEY=your-posthog-key
VITE_POSTHOG_HOST=https://your-instance.posthog.com
